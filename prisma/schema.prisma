generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Categoria {
  id           Int      @id @default(autoincrement())
  nome         String   @unique
  descricao    String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Produto {
  id           Int      @id @default(autoincrement())
  nome         String   @unique
  quantidade   Int
  preco        Float
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}